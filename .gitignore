# ─── Credentials & Secrets ───────────────────
config.json
secrets.py
.env

# ─── Python cache ────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ─── Virtual environments ────────────────────
venv/
env/
.venv/
ENV/

# ─── Logs (keep structure, ignore content) ───
*.log
naukri_run.log

# ─── Excel output (optional — remove this
#     line if you WANT to share sample xlsx) ──
naukri_application_log.xlsx

# ─── OS junk ─────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── IDE files ───────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ─── ChromeDriver cache ───────────────────────
.wdm/
